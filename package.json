{
  "name": "bugproof",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/verify-hooks.mjs",
    "dev": "next dev",
    "version:stamp": "node scripts/stamp-version.mjs",
    "verify:hooks": "node scripts/verify-hooks.mjs",
    "validate:content": "node scripts/validate-content.mjs",
    "prebuild": "node scripts/verify-hooks.mjs && node scripts/validate-content.mjs && sed -i.bak \"s/__BUILD_TIME__/$(date +%s)/\" public/sw.js && rm -f public/sw.js.bak",
    "postbuild": "sed -i.bak \"s/bugproof-[0-9]*/bugproof-__BUILD_TIME__/\" public/sw.js && rm -f public/sw.js.bak",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prepare": "husky"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "next": "16.2.3",
    "next-pwa": "^5.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.0.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "husky": "^9.1.7",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
